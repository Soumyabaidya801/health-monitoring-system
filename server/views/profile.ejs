<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
      @layer utilities {
        .content-auto {
          content-visibility: auto;
        }
      }
    </style>
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <a href="/logout" class="bg-blue-500 text-white px-2 py-1 rounded-xl text-md inline-block">Logout</a>
        <h3 class="text-2xl mb-5">Hello, <%= user.name %></h3>
        <h5 class="mb-5">Create Your Post</h5>
        <form action="/posts" method="post">
            <textarea class="resize-none bg-trasparent border-2 border-zinc-800 p-4" name="content" placeholder="What's on your mind?"></textarea>
            <button class="px-3 py-2 outline-none rounded-md bg-blue-500 block border-2 border-zinc-800" type="submit"> Create Post</button>
        </form>
    </div>
</body>
</html>