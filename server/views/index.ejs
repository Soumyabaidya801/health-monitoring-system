<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
      @layer utilities {
        .content-auto {
          content-visibility: auto;
        }
      }
    </style>
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <form action="/register" method="POST">
            <input class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800" type="text" name="name" placeholder="Name" />
            <input class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800" type="email" name="email" placeholder="Email" />
            <input class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800" type="password" name="password" placeholder="Password" />
            <button class="px-3 py-2 outline-none rounded-md bg-transparent border-2 border-zinc-800" type="submit">Submit</button>
        </form>    
    </div>
</body>
</html>